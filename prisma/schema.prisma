generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Ship {
  id             String     @id @default(cuid())
  name           String
  urlSlug        String     @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  checklistUrl   String?
  regulationsUrl String?
  safetyInfoUrl  String?
  weatherRegId   String?    // 기상청 해상예보 구역 코드 (예: 12A30100)
  limitWind      String?    // 출항 정지 풍속 기준 (예: 12m/s)
  limitWave      String?    // 출항 정지 파고 기준 (예: 2.0m)
  limitVisibility String?   // 출항 정지 가시거리 기준 (예: 1km)
  favoriteCount  Int        @default(0)
  links          ShipLink[]
  visits         Visit[]
}

model ShipLink {
  id          String   @id @default(cuid())
  shipId      String
  title       String
  icon        String?
  url         String
  description String?
  guideText   String?
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  ship        Ship     @relation(fields: [shipId], references: [id], onDelete: Cascade)
}

model Visit {
  id        String   @id @default(cuid())
  shipId    String
  createdAt DateTime @default(now())
  ship      Ship     @relation(fields: [shipId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id              String @id @default("global")
  totalVisitors   Int    @default(0)
  tomorrowWeather String @default("내일의 운항 예보는 날씨가 양호합니다.")
}

model ClickEvent {
  id        String   @id @default(cuid())
  shipId    String
  title     String
  createdAt DateTime @default(now())
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  imageUrl    String?  // Base64 이미지 데이터 저장
  isActive    Boolean  @default(true)
  targetShips String   @default("all") // "all" 이면 공통공지, 아니면 쉼표로 구분된 선박 ID 목록
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

